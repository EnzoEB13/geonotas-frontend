{
  "expo": {
    "name": "GeoNotas",
    "slug": "geonotas",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/iconubi.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/iconubi.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F8FC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/iconubi.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.enzo12.geonotas",
      "permissions": []
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-asset"
    ],
    "owner": "enzoeb12",
    "extra": {
      "eas": {
        "projectId": "7af314d9-f460-403a-ad7d-1633542bf090"
      }
    }
  }
}
