        "backgroundColor": "#ffffff"
      },
      "package": "com.enzo12.geonotas",
      "permissions": []
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "1f987d37-bf01-4eb8-9e2d-890a8d7a729c"
      }
    },
    "owner": "enzoeb12"
  }
}
